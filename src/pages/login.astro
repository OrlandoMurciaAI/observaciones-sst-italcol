---
import '../styles/globals.css';
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acceso | Italcol SST</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
</head>
<body>
    <main class="login-wrapper">
        <div class="login-card glass">
            <header class="text-center">
                <div class="logo">IT</div>
                <h1>Acceso <span>SST</span></h1>
                <p>Ingrese sus credenciales de administrador</p>
            </header>

            <form id="login-form">
                <div class="field">
                    <label for="email">Email Admin</label>
                    <input type="email" id="email" name="email" placeholder="admin@italcol.com" required />
                </div>
                <div class="field">
                    <label for="password">Contraseña</label>
                    <input type="password" id="password" name="password" placeholder="••••••••" required />
                </div>
                <div id="error-msg" class="error-msg hidden">Credenciales inválidas</div>
                
                <button type="submit" class="btn btn-primary w-full" id="submit-btn" disabled={false}>
                    INGRESAR AL SISTEMA
                </button>
            </form>

            <a href="/landing" class="back-link">← Volver al inicio</a>
        </div>
    </main>

    <script>
        const form = document.getElementById('login-form');
        const errorMsg = document.getElementById('error-msg');
        const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target as HTMLFormElement);
            const data = Object.fromEntries(formData.entries());

            submitBtn.innerText = 'Verificando...';
            submitBtn.disabled = true;
            errorMsg?.classList.add('hidden');

            try {
                const res = await fetch('/api/auth', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await res.json();
                if (result.success) {
                    window.location.href = '/';
                } else {
                    errorMsg?.classList.remove('hidden');
                    submitBtn.innerText = 'INGRESAR AL SISTEMA';
                    submitBtn.disabled = false;
                }
            } catch (err) {
                console.error(err);
                submitBtn.innerText = 'INGRESAR AL SISTEMA';
                submitBtn.disabled = false;
            }
        });
    </script>
</body>
</html>

<style>
    body {
        margin: 0;
        font-family: 'Outfit', sans-serif;
        background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-wrapper {
        width: 100%;
        max-width: 420px;
        padding: 2rem;
    }

    .glass {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 30px;
        padding: 3rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .logo {
        background: #ff7a00;
        color: white;
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 14px;
        font-weight: 800;
        font-size: 1.5rem;
        margin: 0 auto 1.5rem;
    }

    h1 {
        font-size: 1.75rem;
        color: white;
        margin-bottom: 0.5rem;
    }

    h1 span {
        color: #ff7a00;
    }

    p {
        color: #94a3b8;
        font-size: 0.9rem;
        margin-bottom: 2.5rem;
    }

    .field {
        margin-bottom: 1.5rem;
        text-align: left;
    }

    label {
        display: block;
        color: #e2e8f0;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    input {
        width: 100%;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 0.75rem 1rem;
        color: white;
        font-size: 1rem;
        transition: all 0.3s;
    }

    input:focus {
        outline: none;
        border-color: #ff7a00;
        background: rgba(255, 255, 255, 0.05);
        box-shadow: 0 0 0 4px rgba(255, 122, 0, 0.1);
    }

    .error-msg {
        color: #f87171;
        font-size: 0.85rem;
        margin-bottom: 1.5rem;
        font-weight: 600;
    }

    .hidden { display: none; }

    .btn-primary {
        background: #ff7a00;
        color: white;
        border: none;
        padding: 1rem;
        border-radius: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .btn-primary:not(:disabled):hover {
        background: #e66e00;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(255, 122, 0, 0.2);
    }

    .btn-primary:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .back-link {
        display: block;
        margin-top: 2rem;
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.85rem;
        transition: color 0.3s;
    }

    .back-link:hover {
        color: white;
    }

    .w-full { width: 100%; }
</style>
