---
import ObservationForm from '../components/ObservationForm.svelte';
import '../styles/globals.css';

// Server-side auth check
const session = Astro.cookies.get('sst_session');
if (!session) {
    return Astro.redirect('/landing');
}
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>SST | Dashboard de Observaciones - Italcol</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
</head>
<body>
    <header class="app-header">
        <div class="container flex justify-between items-center">
            <div class="brand flex items-center gap-md">
                <div class="logo">IT</div>
                <div>
                    <h1>Observaciones de SST</h1>
                    <span class="user-info">Sesión Administrador</span>
                </div>
            </div>
            
            <div class="header-actions flex items-center gap-lg">
                <div class="status-badge flex items-center gap-sm" id="sync-status">
                    <span class="dot"></span>
                    <span id="status-text">Conectando...</span>
                </div>
                <button id="logout-btn" class="logout-btn" title="Cerrar Sesión">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                </button>
            </div>
        </div>
    </header>

    <script>
        // Auth Logic
        document.getElementById('logout-btn')?.addEventListener('click', async () => {
            if(confirm('¿Está seguro de cerrar sesión?')) {
                await fetch('/api/auth', { method: 'DELETE' });
                window.location.href = '/landing';
            }
        });

        // Connectivity Logic
        const updateStatus = () => {
            const statusText = document.getElementById('status-text');
            const dot = document.querySelector('.dot') as HTMLElement;
            if (!statusText || !dot) return;

            if (navigator.onLine) {
                statusText.innerText = 'En Línea';
                dot.style.backgroundColor = 'var(--color-safe)';
                dot.style.boxShadow = '0 0 10px var(--color-safe)';
            } else {
                statusText.innerText = 'Modo Offline';
                dot.style.backgroundColor = 'var(--color-warning)';
                dot.style.boxShadow = '0 0 10px var(--color-warning)';
            }
        };

        window.addEventListener('online', updateStatus);
        window.addEventListener('offline', updateStatus);
        window.addEventListener('sst-synced', () => {
            const statusText = document.getElementById('status-text');
            if (statusText) {
                statusText.innerText = 'Sincronizado ✓';
                setTimeout(updateStatus, 3000);
            }
        });
        updateStatus();
    </script>

    <main class="container main-content">
        <div class="form-header text-center">
            <p class="subtitle">CAPTURA DE DATOS INDUSTRIALES</p>
            <h2>Nueva Observación</h2>
        </div>

        <ObservationForm client:load />
    </main>

    <footer class="app-footer">
        <div class="container">
            <p>&copy; 2024 Italcol - Sistema de Gestión de SST - Área de Seguridad Industrial</p>
        </div>
    </footer>
</body>
</html>

<style>
    :root {
        --color-primary: #1e293b;
        --color-accent: #ff7a00;
        --color-safe: #22c55e;
        --color-warning: #f59e0b;
        --color-white: #ffffff;
        --color-border: #e2e8f0;
    }

    body {
        background-color: #f8fafc;
        font-family: 'Outfit', sans-serif;
        color: var(--color-primary);
        margin: 0;
    }

    .app-header {
        background-color: white;
        border-bottom: 1px solid var(--color-border);
        padding: 1rem 0;
        position: sticky;
        top: 0;
        z-index: 1000;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
    }

    .logo {
        background: var(--color-accent);
        color: white;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        font-weight: 800;
        font-size: 1.1rem;
    }

    h1 {
        font-size: 1.1rem;
        margin: 0;
        font-weight: 700;
    }

    .user-info {
        font-size: 0.75rem;
        color: #64748b;
        font-weight: 600;
    }

    .status-badge {
        font-size: 0.75rem;
        font-weight: 700;
        background-color: #f1f5f9;
        padding: 4px 12px;
        border-radius: 20px;
    }

    .dot {
        width: 8px;
        height: 8px;
        background-color: var(--color-safe);
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    .logout-btn {
        background: none;
        border: none;
        color: #94a3b8;
        cursor: pointer;
        padding: 4px;
        transition: color 0.3s;
    }

    .logout-btn:hover {
        color: #ef4444;
    }

    .main-content {
        padding: 3rem 1rem;
    }

    .form-header {
        margin-bottom: 3rem;
    }

    .subtitle {
        font-size: 0.7rem;
        font-weight: 800;
        color: var(--color-accent);
        letter-spacing: 2px;
        margin-bottom: 0.5rem;
    }

    .form-header h2 {
        font-size: 2.25rem;
        font-weight: 800;
        letter-spacing: -1px;
    }

    .app-footer {
        text-align: center;
        padding: 3rem 0;
        color: #64748b;
        font-size: 0.85rem;
        border-top: 1px solid var(--color-border);
        background-color: white;
    }

    @keyframes pulse {
        0% { opacity: 1; }
        50% { opacity: 0.5; }
        100% { opacity: 1; }
    }

    @media (max-width: 600px) {
        .user-info { display: none; }
    }
</style>
