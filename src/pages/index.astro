---
import ObservationForm from '../components/ObservationForm.svelte';
import '../styles/globals.css';
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>SST | Observaciones de Comportamiento - Italcol</title>
    <meta name="description" content="Formato digital para la captura de observaciones de comportamiento en entornos industriales (SST). Bypassing Supabase for fast prototyping." />
</head>
<body>
    <header class="app-header">
        <div class="container flex justify-between items-center">
            <div class="brand flex items-center gap-md">
                <div class="logo-placeholder">IT</div>
                <h1>Observaciones de Comportamiento</h1>
            </div>
            <div class="status-badge flex items-center gap-sm">
                <span class="dot"></span>
                <span>En Línea (Storage Local)</span>
            </div>
        </div>
    </header>

    <main class="container">
        <div class="hero-intro">
            <p>Registre las observaciones de seguridad basándose en los 17 puntos de comportamiento críticos para la operación de Italcol.</p>
        </div>

        <ObservationForm client:load />
    </main>

    <footer class="app-footer">
        <div class="container">
            <p>&copy; 2024 Italcol - Sistema de Gestión de SST - Área de Seguridad Industrial</p>
        </div>
    </footer>
</body>
</html>

<style>
    .app-header {
        background-color: var(--color-white);
        border-bottom: 2px solid var(--color-border);
        padding: var(--space-md) 0;
        margin-bottom: var(--space-xl);
    }

    .brand h1 {
        font-size: 1.25rem;
        margin: 0;
        color: var(--color-primary);
        letter-spacing: -0.5px;
    }

    .logo-placeholder {
        background-color: var(--color-cta);
        color: white;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-md);
        font-weight: 900;
        font-size: 1.2rem;
    }

    .status-badge {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--color-safe);
        background-color: #f0fdf4;
        padding: 4px 10px;
        border-radius: 20px;
        border: 1px solid #dcfce7;
    }

    .dot {
        width: 8px;
        height: 8px;
        background-color: var(--color-safe);
        border-radius: 50%;
        box-shadow: 0 0 10px var(--color-safe);
        animation: pulse 2s infinite;
    }

    .hero-intro {
        text-align: center;
        max-width: 600px;
        margin: 0 auto var(--space-2xl);
        color: var(--color-secondary);
        font-size: 1.1rem;
    }

    .app-footer {
        text-align: center;
        padding: var(--space-2xl) 0;
        color: var(--color-secondary);
        font-size: 0.85rem;
        border-top: 1px solid var(--color-border);
    }

    @keyframes pulse {
        0% { opacity: 1; }
        50% { opacity: 0.5; }
        100% { opacity: 1; }
    }

    @media (max-width: 600px) {
        .brand h1 {
            font-size: 1rem;
        }
        .status-badge {
            display: none;
        }
    }
</style>
