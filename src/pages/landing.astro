---
import '../styles/globals.css';
const session = Astro.cookies.get('sst_session');
const isAuthenticated = !!session;
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Italcol SST | Sistema de Observaciones</title>
    <meta name="description" content="Sistema profesional de captura de datos SST para entornos industriales." />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
</head>
<body class="landing-page">
    <div class="glow-bg"></div>
    
    <header class="navbar container flex justify-between items-center">
        <div class="brand flex items-center gap-md">
            <div class="logo">IT</div>
            <span class="brand-name">Italcol <span>SST</span></span>
        </div>
        <div class="flex items-center gap-lg">
            {isAuthenticated && <a href="/dashboard" class="login-link">Dashboard</a>}
            <a href="/login" class="login-link">{isAuthenticated ? 'Mi Perfil' : 'Acceso Personal'}</a>
        </div>
    </header>


    <main class="hero container flex flex-col items-center text-center">
        <div class="badge">Estandar de Seguridad Industrial</div>
        <h1>Sistema de Gestión de <span>Comportamientos Críticos</span></h1>
        <p>Captura de datos robusta, diseñada para la planta y optimizada para operar en condiciones de baja conectividad.</p>
        
        <div class="cta-group flex gap-md">
            <a href={isAuthenticated ? "/" : "/login"} class="btn btn-primary btn-lg">Iniciar Registro</a>
            <a href="#features" class="btn btn-outline btn-lg">Saber más</a>
        </div>

        <div class="stats-preview grid grid-cols-3 gap-xl">
            <div class="stat-card">
                <span class="number">17</span>
                <span class="label">Puntos de Control</span>
            </div>
            <div class="stat-card">
                <span class="number">100%</span>
                <span class="label">Modo Offline</span>
            </div>
            <div class="stat-card">
                <span class="number">💾</span>
                <span class="label">Auto-guardado</span>
            </div>
        </div>
    </main>

    <section id="features" class="features container">
        <div class="section-header text-center">
            <h2>Diseñado para el <span>Campo</span></h2>
        </div>
        <div class="grid grid-cols-3 gap-lg">
            <div class="feature-card">
                <div class="icon">📡</div>
                <h3>Tolerancia a Fallos</h3>
                <p>Nuestra tecnología de sesiones persistentes garantiza que nunca pierdas un dato, incluso sin internet.</p>
            </div>
            <div class="feature-card">
                <div class="icon">⚡</div>
                <h3>Máxima Rapidez</h3>
                <p>Autocerrado inteligente y sugerencias basadas en planta para registros en segundos.</p>
            </div>
            <div class="feature-card">
                <div class="icon">📊</div>
                <h3>Datos de Valor</h3>
                <p>Sincronización directa con Supabase para análisis preventivo en tiempo real.</p>
            </div>
        </div>
    </section>

    <footer class="footer container text-center">
        <p>&copy; 2024 Italcol - Área de Seguridad y Salud en el Trabajo</p>
    </footer>
</body>
</html>

<style>
    :root {
        --color-primary: #1e293b;
        --color-accent: #ff7a00;
        --color-accent-soft: rgba(255, 122, 0, 0.1);
        --color-white: #ffffff;
        --color-text: #475569;
        --font-main: 'Outfit', sans-serif;
    }

    body.landing-page {
        margin: 0;
        font-family: var(--font-main);
        background-color: #f8fafc;
        color: var(--color-primary);
        line-height: 1.6;
        overflow-x: hidden;
    }

    .glow-bg {
        position: fixed;
        top: -10%;
        right: -10%;
        width: 50%;
        height: 50%;
        background: radial-gradient(circle, rgba(255, 122, 0, 0.05) 0%, transparent 70%);
        z-index: -1;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .navbar {
        height: 80px;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .logo {
        background: var(--color-accent);
        color: white;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        font-weight: 800;
        font-size: 1.2rem;
    }

    .brand-name {
        font-weight: 700;
        font-size: 1.25rem;
        letter-spacing: -0.5px;
    }

    .brand-name span {
        color: var(--color-accent);
    }

    .login-link {
        font-weight: 600;
        color: var(--color-text);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.3s;
    }

    .login-link:hover {
        color: var(--color-accent);
    }

    .hero {
        padding: 5rem 0 8rem;
    }

    .badge {
        background: var(--color-accent-soft);
        color: var(--color-accent);
        padding: 0.5rem 1rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 2rem;
    }

    h1 {
        font-size: 4rem;
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 2rem;
        letter-spacing: -2px;
    }

    h1 span {
        display: block;
        color: var(--color-accent);
    }

    p {
        font-size: 1.25rem;
        color: var(--color-text);
        max-width: 600px;
        margin-bottom: 3rem;
    }

    .btn {
        padding: 1rem 2rem;
        border-radius: 12px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s;
    }

    .btn-primary {
        background: var(--color-accent);
        color: white;
        box-shadow: 0 10px 20px rgba(255, 122, 0, 0.2);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 30px rgba(255, 122, 0, 0.3);
    }

    .btn-outline {
        border: 2px solid var(--color-primary);
        color: var(--color-primary);
    }

    .btn-outline:hover {
        background: var(--color-primary);
        color: white;
    }

    .stats-preview {
        margin-top: 6rem;
        width: 100%;
        max-width: 800px;
    }

    .stat-card {
        padding: 2rem;
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
        border: 1px solid #f1f5f9;
        transition: transform 0.3s;
    }

    .stat-card:hover {
        transform: translateY(-5px);
    }

    .number {
        display: block;
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--color-accent);
        margin-bottom: 0.25rem;
    }

    .label {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--color-text);
    }

    .features {
        padding: 8rem 0;
        background-color: white;
    }

    .section-header h2 {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 4rem;
    }

    .section-header span {
        color: var(--color-accent);
    }

    .feature-card {
        padding: 3rem 2rem;
        background: #f8fafc;
        border-radius: 24px;
        transition: all 0.3s;
    }

    .feature-card:hover {
        background: white;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
        transform: translateY(-5px);
    }

    .icon {
        font-size: 3rem;
        margin-bottom: 1.5rem;
    }

    .feature-card h3 {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
    }

    .footer {
        padding: 4rem 0;
        border-top: 1px solid #e2e8f0;
        font-size: 0.9rem;
        color: var(--color-text);
    }

    @media (max-width: 768px) {
        h1 { font-size: 2.5rem; }
        .grid-cols-3 { grid-template-columns: 1fr; }
        .stats-preview { margin-top: 3rem; }
    }
</style>
